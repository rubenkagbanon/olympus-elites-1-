# Copy this file to .env and fill in real values.
# .env is already gitignored — never commit real secrets.

# Google Maps JavaScript API key, used by client/src/components/Map.tsx
# Get one at https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=

# Port the Express server listens on in production (optional, defaults to 3000)
PORT=3000
